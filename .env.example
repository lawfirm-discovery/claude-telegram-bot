# ============================================================
# claude-telegram-bot 환경변수 (.env)
# ============================================================
# 복사 후 수정: cp .env.example .env && nano .env

# === 필수: 서버별로 다른 값 ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_USERS=62649819

# === Claude CLI ===
CLAUDE_PATH=/home/angrylawyer/.local/bin/claude
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_LIGHT_MODEL=claude-sonnet-4-6
CLAUDE_EFFORT=medium                # low | medium | high | max

# === 토큰 최적화 ===
ENABLE_MODEL_ROUTING=true           # 간단한 질문→sonnet, 복잡→opus 자동 라우팅
USE_BARE_MODE=false                 # true=ANTHROPIC_API_KEY 전용 (OAuth 사용 시 반드시 false)
ALLOWED_TOOLS=                      # 비워두면 모든 도구 사용 (MCP/Figma 포함). 제한: Bash,Edit,Read,Write,Glob,Grep

# === 타임아웃 (OpenClaw 정렬) ===
TIMEOUT_MS=1200000
SESSION_TTL_MS=3600000

# === 기타 ===
MAX_TURNS=200                       # 안전망 (진짜 runaway만 차단, 0=무제한)
DEBOUNCE_MS=1500
SYSTEM_PROMPT=
GROUP_MENTION_PATTERNS=대답해
